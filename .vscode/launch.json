{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "BridgeMonitor: build and debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\build-vscode-qmake\\debug\\BridgeMonitor.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "Path",
                    "value": "D:\\App\\Qt\\Tools\\mingw1310_64\\bin;D:\\App\\Qt\\6.11.0\\mingw_64\\bin;${env:Path}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\App\\Qt\\Tools\\mingw1310_64\\bin\\gdb.exe",
            "preLaunchTask": "qmake: build",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
